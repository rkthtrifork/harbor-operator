{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "digest": { "type": "string" },
        "pullPolicy": { "type": "string" },
        "pullSecrets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" }
            },
            "required": ["name"]
          }
        }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "secure": { "type": "boolean" },
        "bindAddress": { "type": "string" },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" },
            "labels": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      }
    },
    "resources": { "type": "object" },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "podLabels": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "priorityClassName": { "type": "string" },
    "podSecurityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "env": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "pdb": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string", "null"] },
        "maxUnavailable": { "type": ["integer", "string", "null"] }
      }
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "maxSkew": { "type": "integer" },
          "topologyKey": { "type": "string" },
          "whenUnsatisfiable": { "type": "string" },
          "labelSelector": { "type": "object" },
          "minDomains": { "type": "integer" },
          "nodeAffinityPolicy": { "type": "string" },
          "nodeTaintsPolicy": { "type": "string" },
          "matchLabelKeys": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["maxSkew", "topologyKey", "whenUnsatisfiable"],
        "additionalProperties": true
      }
    }
    ,
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "type": {
          "type": "string",
          "enum": ["kubernetes", "cilium"]
        },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "metrics": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "namespaces": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        },
        "egress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowKubeAPI": { "type": "boolean" },
            "kubeAPIPorts": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              }
            },
            "allowDNS": { "type": "boolean" },
            "harborSelectors": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "namespace": { "type": "string" },
                  "namespaceSelector": { "type": "object" },
                  "podSelector": { "type": "object" }
                },
                "anyOf": [
                  { "required": ["namespace"] },
                  { "required": ["namespaceSelector"] }
                ]
              }
            }
          }
        }
      }
    }
  }
}
